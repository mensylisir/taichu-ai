{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "━━━ 命名空间与应用分布 (NAMESPACE & APP) ━━━",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 200,
      "targets": [
        {
          "expr": "count(count by (namespace) (dcgm_gpu_utilization))",
          "refId": "A"
        }
      ],
      "title": "正在使用 GPU 的项目数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 201,
      "targets": [
        { "expr": "count(count by (pod) (dcgm_gpu_utilization))", "refId": "A" }
      ],
      "title": "运行中的 GPU Pod 数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 202,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (namespace) (dcgm_fb_used)",
          "legendFormat": "Namespace: {{namespace}}",
          "refId": "A"
        }
      ],
      "title": "各项目显存占用排行 (MB)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 5 },
      "id": 203,
      "targets": [
        {
          "expr": "avg by (pod) (dcgm_gpu_utilization{namespace=~\"$namespace\"} or (dcgm_fi_prof_gr_engine_active{namespace=~\"$namespace\"}*100))",
          "legendFormat": "Pod: {{pod}}",
          "refId": "A"
        }
      ],
      "title": "应用级算力负载 (Pod Utilization)",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 2,
      "title": "━━━ 应用显存与流量明细 (POD MEMORY & TRAFFIC) ━━━",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "megabytes" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 204,
      "targets": [
        {
          "expr": "sum by (pod, container) (dcgm_fb_used{namespace=~\"$namespace\"})",
          "legendFormat": "容器: {{container}} (Pod: {{pod}})",
          "refId": "A"
        }
      ],
      "title": "具体容器显存消耗趋势",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 205,
      "targets": [
        {
          "expr": "sum by (pod) (irate(dcgm_fi_prof_pcie_tx_bytes{namespace=~\"$namespace\"}[2m]))",
          "legendFormat": "Pod: {{pod}} (TX)",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (irate(dcgm_fi_prof_pcie_rx_bytes{namespace=~\"$namespace\"}[2m]))",
          "legendFormat": "Pod: {{pod}} (RX)",
          "refId": "B"
        }
      ],
      "title": "应用级 PCIe 带宽消耗 (Pod 维度数据交换频率)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 42,
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(dcgm_gpu_utilization, namespace)",
        "name": "namespace",
        "query": "label_values(dcgm_gpu_utilization, namespace)",
        "refresh": 1,
        "type": "query",
        "multi": true,
        "includeAll": true
      },
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(dcgm_gpu_utilization{namespace=~\"$namespace\"}, pod)",
        "includeAll": true,
        "multi": true,
        "name": "pod",
        "query": "label_values(dcgm_gpu_utilization{namespace=~\"$namespace\"}, pod)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "title": "GPU 应用监控中心 (K8s Pod 维度)",
  "uid": "gpu-app-monitor"
}
